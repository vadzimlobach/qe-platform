{
    "compilerOptions": {
        "target": "es2022",
        "module": "esnext",
        "moduleResolution": "bundler",

        "strict": true,

        "types": ["node", "@playwright/test"],

        "resolveJsonModule": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
    },

    "include": [
        "tests",
        "framework",
        "config",
        "playwright.config.ts"
    ],
}